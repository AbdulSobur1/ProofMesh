generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String           @id @default(cuid())
  username            String           @unique
  passwordHash        String
  displayName         String?
  headline            String?
  bio                 String?
  location            String?
  websiteUrl          String?
  avatarUrl           String?
  currentRole         String?
  currentCompany      String?
  yearsExperience     Int?
  createdAt           DateTime         @default(now())
  proofs              Proof[]
  workExperiences     WorkExperience[]
  educations          Education[]
  certifications      Certification[]
  claimedSkills       ClaimedSkill[]
  sentConnections     Connection[]     @relation("ConnectionRequester")
  receivedConnections Connection[]     @relation("ConnectionRecipient")
  conversationMemberships ConversationParticipant[]
  sentMessages        Message[]
  posts               Post[]
  jobApplications     JobApplication[]
  savedCandidates     SavedCandidate[] @relation("RecruiterSavedCandidates")
  candidateShortlists SavedCandidate[] @relation("CandidateSavedByRecruiters")
  jobs                JobPost[]
}

model Connection {
  id           String   @id @default(cuid())
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  respondedAt  DateTime?
  requesterId  String
  recipientId  String
  requester    User     @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient    User     @relation("ConnectionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([requesterId, status])
  @@index([recipientId, status])
  @@index([createdAt])
}

model Conversation {
  id              String                    @id @default(cuid())
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  lastMessageAt   DateTime?
  participants    ConversationParticipant[]
  messages        Message[]

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id              String        @id @default(cuid())
  joinedAt        DateTime      @default(now())
  lastReadAt      DateTime?
  conversationId  String
  userId          String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String        @id @default(cuid())
  body            String
  createdAt       DateTime      @default(now())
  conversationId  String
  senderId        String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model Post {
  id          String   @id @default(cuid())
  body        String
  postType    String   @default("text")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  proofId     String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  proof       Proof?   @relation(fields: [proofId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([proofId])
  @@index([createdAt])
}

model WorkExperience {
  id           String   @id @default(cuid())
  title        String
  company      String
  location     String?
  startDate    String
  endDate      String?
  isCurrent    Boolean  @default(false)
  description  String?
  displayOrder Int      @default(0)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, displayOrder])
}

model Education {
  id            String   @id @default(cuid())
  school        String
  degree        String
  fieldOfStudy  String?
  startDate     String?
  endDate       String?
  description   String?
  displayOrder  Int      @default(0)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, displayOrder])
}

model Certification {
  id            String   @id @default(cuid())
  name          String
  issuer        String
  issueDate     String?
  credentialUrl String?
  displayOrder  Int      @default(0)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, displayOrder])
}

model ClaimedSkill {
  id            String   @id @default(cuid())
  name          String
  displayOrder  Int      @default(0)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, displayOrder])
}

model Proof {
  id                     String             @id @default(cuid())
  title                  String
  description            String
  link                   String?
  profession             String             @default("software_engineering")
  proofType              String             @default("project")
  outcomeSummary         String?
  score                  Int
  feedback               String?
  tags                   String
  txHash                 String
  verificationStatus     String             @default("needs_review")
  verificationConfidence Int                @default(50)
  verificationSignals    String             @default("[]")
  verifiedAt             DateTime?
  createdAt              DateTime           @default(now())
  userId                 String
  user                   User               @relation(fields: [userId], references: [id])
  endorsements           ProofEndorsement[]
  posts                  Post[]
  jobApplications        JobApplication[]

  @@index([userId])
  @@index([createdAt])
  @@index([profession])
  @@index([verificationStatus])
}

model ProofEndorsement {
  id              String   @id @default(cuid())
  verifierName    String
  verifierRole    String?
  verifierCompany String?
  relationship    String
  message         String
  createdAt       DateTime @default(now())
  proofId         String
  proof           Proof     @relation(fields: [proofId], references: [id], onDelete: Cascade)

  @@index([proofId])
  @@index([relationship])
  @@index([createdAt])
}

model SavedCandidate {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  recruiterId String
  candidateId String
  recruiter   User     @relation("RecruiterSavedCandidates", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidate   User     @relation("CandidateSavedByRecruiters", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([recruiterId, candidateId])
  @@index([recruiterId])
  @@index([candidateId])
  @@index([createdAt])
}

model JobPost {
  id                  String   @id @default(cuid())
  title               String
  description         String
  profession          String
  targetTags          String   @default("[]")
  preferredProofTypes String   @default("[]")
  minScore            Float    @default(7)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  recruiterId         String
  recruiter           User     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  applications        JobApplication[]

  @@index([recruiterId])
  @@index([profession])
  @@index([createdAt])
}

model JobApplication {
  id             String   @id @default(cuid())
  status         String   @default("submitted")
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  jobId          String
  applicantId    String
  selectedProofId String?
  job            JobPost  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant      User     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  selectedProof  Proof?   @relation(fields: [selectedProofId], references: [id], onDelete: SetNull)

  @@unique([jobId, applicantId])
  @@index([jobId, status])
  @@index([applicantId, status])
  @@index([createdAt])
}
