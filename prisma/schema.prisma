generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  proofs       Proof[]
}

model Proof {
  id          String   @id @default(cuid())
  title       String
  description String
  link        String?
  score       Int
  feedback    String?
  tags        String
  txHash      String
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}
