generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String           @id @default(cuid())
  username            String           @unique
  passwordHash        String
  displayName         String?
  headline            String?
  bio                 String?
  location            String?
  websiteUrl          String?
  avatarUrl           String?
  currentRole         String?
  currentCompany      String?
  yearsExperience     Int?
  createdAt           DateTime         @default(now())
  proofs              Proof[]
  workExperiences     WorkExperience[]
  educations          Education[]
  certifications      Certification[]
  claimedSkills       ClaimedSkill[]
  sentConnections     Connection[]     @relation("ConnectionRequester")
  receivedConnections Connection[]     @relation("ConnectionRecipient")
  conversationMemberships ConversationParticipant[]
  sentMessages        Message[]
  posts               Post[]
  postLikes           PostLike[]
  postComments        PostComment[]
  jobApplications     JobApplication[]
  ownedCompanies      Company[]        @relation("CompanyOwner")
  companyMemberships  CompanyMember[]
  savedCandidates     SavedCandidate[] @relation("RecruiterSavedCandidates")
  candidateShortlists SavedCandidate[] @relation("CandidateSavedByRecruiters")
  jobs                JobPost[]
  notifications       Notification[]   @relation("UserNotifications")
  actorNotifications  Notification[]   @relation("NotificationActor")
  profileViewsReceived ProfileView[]   @relation("ProfileViewProfile")
  profileViewsSent     ProfileView[]   @relation("ProfileViewViewer")
  savedSearches        SavedSearch[]
  companyFollows       CompanyFollow[]
  companyPosts         CompanyPost[]   @relation("CompanyPostAuthor")
  reports              Report[]
}

model Company {
  id             String          @id @default(cuid())
  slug           String          @unique
  name           String
  tagline        String?
  description    String?
  websiteUrl     String?
  location       String?
  logoUrl        String?
  industry       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ownerId        String
  owner          User            @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members        CompanyMember[]
  jobs           JobPost[]
  followers      CompanyFollow[]
  posts          CompanyPost[]

  @@index([ownerId])
  @@index([name])
}

model CompanyMember {
  id          String   @id @default(cuid())
  role        String   @default("admin")
  createdAt   DateTime @default(now())
  companyId   String
  userId      String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
}

model Connection {
  id           String   @id @default(cuid())
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  respondedAt  DateTime?
  requesterId  String
  recipientId  String
  requester    User     @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient    User     @relation("ConnectionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([requesterId, status])
  @@index([recipientId, status])
  @@index([createdAt])
}

model Conversation {
  id              String                    @id @default(cuid())
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  lastMessageAt   DateTime?
  participants    ConversationParticipant[]
  messages        Message[]

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id              String        @id @default(cuid())
  joinedAt        DateTime      @default(now())
  lastReadAt      DateTime?
  conversationId  String
  userId          String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String        @id @default(cuid())
  body            String
  createdAt       DateTime      @default(now())
  conversationId  String
  senderId        String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())
  userId    String
  actorId   String?
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([actorId])
  @@index([type])
}

model ProfileView {
  id            String   @id @default(cuid())
  firstViewedAt DateTime @default(now())
  lastViewedAt  DateTime @default(now())
  viewCount     Int      @default(1)
  profileUserId String
  viewerUserId  String
  profileUser   User     @relation("ProfileViewProfile", fields: [profileUserId], references: [id], onDelete: Cascade)
  viewerUser    User     @relation("ProfileViewViewer", fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@unique([profileUserId, viewerUserId])
  @@index([profileUserId, lastViewedAt])
  @@index([viewerUserId, lastViewedAt])
}

model SavedSearch {
  id              String   @id @default(cuid())
  query           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastResultCount Int      @default(0)
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, query])
  @@index([ownerId, updatedAt])
}

model CompanyFollow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  companyId  String
  userId     String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId, createdAt])
  @@index([userId, createdAt])
}

model CompanyPost {
  id         String   @id @default(cuid())
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  companyId  String
  authorId   String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  author     User     @relation("CompanyPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([authorId, createdAt])
}

model Report {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  reason     String
  details    String?
  status     String   @default("open")
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId, status])
  @@index([reporterId, createdAt])
  @@index([status, createdAt])
}

model Post {
  id          String   @id @default(cuid())
  body        String
  postType    String   @default("text")
  moderationStatus String @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  proofId     String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  proof       Proof?   @relation(fields: [proofId], references: [id], onDelete: SetNull)
  likes       PostLike[]
  comments    PostComment[]

  @@index([userId, createdAt])
  @@index([proofId])
  @@index([createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model PostComment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model WorkExperience {
  id           String   @id @default(cuid())
  title        String
  company      String
  location     String?
  startDate    String
  endDate      String?
  isCurrent    Boolean  @default(false)
  description  String?
  displayOrder Int      @default(0)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, displayOrder])
}

model Education {
  id            String   @id @default(cuid())
  school        String
  degree        String
  fieldOfStudy  String?
  startDate     String?
  endDate       String?
  description   String?
  displayOrder  Int      @default(0)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, displayOrder])
}

model Certification {
  id            String   @id @default(cuid())
  name          String
  issuer        String
  issueDate     String?
  credentialUrl String?
  displayOrder  Int      @default(0)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, displayOrder])
}

model ClaimedSkill {
  id            String   @id @default(cuid())
  name          String
  displayOrder  Int      @default(0)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, displayOrder])
}

model Proof {
  id                     String             @id @default(cuid())
  title                  String
  description            String
  link                   String?
  profession             String             @default("software_engineering")
  proofType              String             @default("project")
  outcomeSummary         String?
  score                  Int
  feedback               String?
  tags                   String
  txHash                 String
  verificationStatus     String             @default("needs_review")
  verificationConfidence Int                @default(50)
  verificationSignals    String             @default("[]")
  riskScore              Int                @default(0)
  riskFlags              String             @default("[]")
  moderationStatus       String             @default("active")
  verifiedAt             DateTime?
  createdAt              DateTime           @default(now())
  userId                 String
  user                   User               @relation(fields: [userId], references: [id])
  endorsements           ProofEndorsement[]
  posts                  Post[]
  jobApplications        JobApplication[]

  @@index([userId])
  @@index([createdAt])
  @@index([profession])
  @@index([verificationStatus])
}

model ProofEndorsement {
  id              String   @id @default(cuid())
  verifierName    String
  verifierRole    String?
  verifierCompany String?
  relationship    String
  message         String
  createdAt       DateTime @default(now())
  proofId         String
  proof           Proof     @relation(fields: [proofId], references: [id], onDelete: Cascade)

  @@index([proofId])
  @@index([relationship])
  @@index([createdAt])
}

model SavedCandidate {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  recruiterId String
  candidateId String
  recruiter   User     @relation("RecruiterSavedCandidates", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidate   User     @relation("CandidateSavedByRecruiters", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([recruiterId, candidateId])
  @@index([recruiterId])
  @@index([candidateId])
  @@index([createdAt])
}

model JobPost {
  id                  String   @id @default(cuid())
  title               String
  description         String
  profession          String
  targetTags          String   @default("[]")
  preferredProofTypes String   @default("[]")
  minScore            Float    @default(7)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  recruiterId         String
  companyId           String?
  recruiter           User     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  company             Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  applications        JobApplication[]

  @@index([recruiterId])
  @@index([profession])
  @@index([createdAt])
}

model JobApplication {
  id             String   @id @default(cuid())
  status         String   @default("submitted")
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  jobId          String
  applicantId    String
  selectedProofId String?
  job            JobPost  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant      User     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  selectedProof  Proof?   @relation(fields: [selectedProofId], references: [id], onDelete: SetNull)

  @@unique([jobId, applicantId])
  @@index([jobId, status])
  @@index([applicantId, status])
  @@index([createdAt])
}
