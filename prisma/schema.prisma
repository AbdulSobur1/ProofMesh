generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String           @id @default(cuid())
  username            String           @unique
  passwordHash        String
  displayName         String?
  headline            String?
  bio                 String?
  location            String?
  websiteUrl          String?
  avatarUrl           String?
  currentRole         String?
  currentCompany      String?
  yearsExperience     Int?
  createdAt           DateTime         @default(now())
  proofs              Proof[]
  savedCandidates     SavedCandidate[] @relation("RecruiterSavedCandidates")
  candidateShortlists SavedCandidate[] @relation("CandidateSavedByRecruiters")
  jobs                JobPost[]
}

model Proof {
  id                     String             @id @default(cuid())
  title                  String
  description            String
  link                   String?
  profession             String             @default("software_engineering")
  proofType              String             @default("project")
  outcomeSummary         String?
  score                  Int
  feedback               String?
  tags                   String
  txHash                 String
  verificationStatus     String             @default("needs_review")
  verificationConfidence Int                @default(50)
  verificationSignals    String             @default("[]")
  verifiedAt             DateTime?
  createdAt              DateTime           @default(now())
  userId                 String
  user                   User               @relation(fields: [userId], references: [id])
  endorsements           ProofEndorsement[]

  @@index([userId])
  @@index([createdAt])
  @@index([profession])
  @@index([verificationStatus])
}

model ProofEndorsement {
  id              String   @id @default(cuid())
  verifierName    String
  verifierRole    String?
  verifierCompany String?
  relationship    String
  message         String
  createdAt       DateTime @default(now())
  proofId         String
  proof           Proof     @relation(fields: [proofId], references: [id], onDelete: Cascade)

  @@index([proofId])
  @@index([relationship])
  @@index([createdAt])
}

model SavedCandidate {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  recruiterId String
  candidateId String
  recruiter   User     @relation("RecruiterSavedCandidates", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidate   User     @relation("CandidateSavedByRecruiters", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([recruiterId, candidateId])
  @@index([recruiterId])
  @@index([candidateId])
  @@index([createdAt])
}

model JobPost {
  id                  String   @id @default(cuid())
  title               String
  description         String
  profession          String
  targetTags          String   @default("[]")
  preferredProofTypes String   @default("[]")
  minScore            Float    @default(7)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  recruiterId         String
  recruiter           User     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  @@index([recruiterId])
  @@index([profession])
  @@index([createdAt])
}
